{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoCompactEnabled": true,
  "autoMemoryEnabled": true,
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fdx *)",
      "Bash(terraform apply *)",
      "Bash(terraform destroy *)",
      "Bash(kubectl delete *)",
      "Bash(docker system prune *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(gh pr merge *)",
      "Bash(npm publish *)",
      "Bash(pnpm publish *)",
      "Bash(yarn publish *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/pre_tool_guard.ps1",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/mark_needs_verification.ps1",
            "timeout": 10
          },
          {
            "type": "command",
            "shell": "powershell",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/mark_wiki_review_needed.ps1",
            "timeout": 10
          },
          {
            "type": "command",
            "shell": "powershell",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/mark_wiki_updated.ps1",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/mark_verified_if_test_ran.ps1",
            "timeout": 10
          },
          {
            "type": "command",
            "shell": "powershell",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/track_skill_opportunities.ps1",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/stop_requires_verification.ps1",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
